EOF
    chmod +x /usr/local/bin/mainuser

    cat > /usr/local/bin/newuser << 'EOF'
#!/bin/bash
set -Eeuo pipefail
CONFIG_DIR="/usr/local/etc/xray"
CONFIG_FILE="$CONFIG_DIR/config.json"
KEYS_FILE="$CONFIG_DIR/.keys"

die() {
    echo "Ошибка: $*" >&2
    exit 1
}

key_value() {
    local name="$1"
    local value
    value="$(awk -F': *' -v name="$name" 'BEGIN { IGNORECASE = 1 } $1 == name { print $2; exit }' "$KEYS_FILE")"
    [[ -n "$value" ]] || return 1
    printf '%s\n' "$value"
}

public_key() {
    key_value Password || key_value PublicKey || key_value "Public key"
}

backup_config() {
    local backup
    backup="$CONFIG_FILE.bak.$(date +%Y%m%d-%H%M%S)"
    cp -p "$CONFIG_FILE" "$backup"
    printf '%s\n' "$backup"
}

validate_config() {
    jq -e . "$1" >/dev/null
    if command -v xray >/dev/null 2>&1; then
        xray run -test -config "$1" >/dev/null
    fi
}

restart_or_rollback() {
    local backup="$1"
    if systemctl restart xray; then
        return
    fi

    cp -p "$backup" "$CONFIG_FILE"
    systemctl restart xray >/dev/null 2>&1 || true
    die "не удалось перезапустить xray, конфиг восстановлен из $backup"
}

read -r -p "Введите имя пользователя (email): " email

if [[ -z "$email" || "$email" == *" "* ]]; then
    die "Имя пользователя не может быть пустым или содержать пробелы. Попробуйте снова."
fi

if jq -e --arg email "$email" '.inbounds[0].settings.clients[] | select(.email == $email)' "$CONFIG_FILE" >/dev/null; then
    die "Пользователь с таким именем уже существует. Попробуйте снова."
fi

uuid="$(xray uuid)"
tmp="$(mktemp "$CONFIG_DIR/config.json.XXXXXX")"
chmod 644 "$tmp"
jq --arg email "$email" --arg uuid "$uuid" \
   '.inbounds[0].settings.clients += [{"email": $email, "id": $uuid, "flow": ""}]' \
   "$CONFIG_FILE" > "$tmp"
validate_config "$tmp"
backup="$(backup_config)"
mv "$tmp" "$CONFIG_FILE"
restart_or_rollback "$backup"

index="$(jq --arg email "$email" '.inbounds[0].settings.clients | to_entries[] | select(.value.email == $email) | .key' "$CONFIG_FILE")"
protocol="$(jq -r '.inbounds[0].protocol' "$CONFIG_FILE")"
port="$(jq -r '.inbounds[0].port' "$CONFIG_FILE")"
uuid="$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].id' "$CONFIG_FILE")"
pbk="$(public_key)"
sid="$(key_value shortsid)"
username="$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].email' "$CONFIG_FILE")"
sni="$(jq -r '.inbounds[0].streamSettings.realitySettings.serverNames[0]' "$CONFIG_FILE")"
ip="$(timeout 3 curl -4 -fsS icanhazip.com)"
link="$protocol://$uuid@$ip:$port?security=reality&path=%2F&host=&mode=auto&sni=$sni&fp=firefox&pbk=$pbk&sid=$sid&spx=%2F&type=xhttp&encryption=none#$username"

echo ""
echo "Ссылка для подключения:"
echo "$link"
echo ""
echo "QR-код:"
printf '%s' "$link" | qrencode -t ansiutf8
EOF
    chmod +x /usr/local/bin/newuser

    cat > /usr/local/bin/rmuser << 'EOF'
#!/bin/bash
set -Eeuo pipefail
CONFIG_DIR="/usr/local/etc/xray"
CONFIG_FILE="$CONFIG_DIR/config.json"

die() {
    echo "Ошибка: $*" >&2
    exit 1
}

backup_config() {
    local backup
    backup="$CONFIG_FILE.bak.$(date +%Y%m%d-%H%M%S)"
    cp -p "$CONFIG_FILE" "$backup"
    printf '%s\n' "$backup"
}

validate_config() {
    jq -e . "$1" >/dev/null
    if command -v xray >/dev/null 2>&1; then
        xray run -test -config "$1" >/dev/null
    fi
}

restart_or_rollback() {
    local backup="$1"
    if systemctl restart xray; then
        return
    fi

    cp -p "$backup" "$CONFIG_FILE"
    systemctl restart xray >/dev/null 2>&1 || true
    die "не удалось перезапустить xray, конфиг восстановлен из $backup"
}

mapfile -t emails < <(jq -r '.inbounds[0].settings.clients[].email' "$CONFIG_FILE")

if [[ ${#emails[@]} -eq 0 ]]; then
    die "Нет клиентов для удаления."
fi

echo "Список клиентов:"
for i in "${!emails[@]}"; do
    echo "$((i + 1)). ${emails[$i]}"
done

read -r -p "Введите номер клиента для удаления: " choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#emails[@]} )); then
    die "номер должен быть от 1 до ${#emails[@]}"
fi

selected_email="${emails[$((choice - 1))]}"
tmp="$(mktemp "$CONFIG_DIR/config.json.XXXXXX")"
chmod 644 "$tmp"
jq --arg email "$selected_email" \
   '(.inbounds[0].settings.clients) |= map(select(.email != $email))' \
   "$CONFIG_FILE" > "$tmp"
validate_config "$tmp"
backup="$(backup_config)"
mv "$tmp" "$CONFIG_FILE"
restart_or_rollback "$backup"

echo "Клиент $selected_email удалён."
EOF
    chmod +x /usr/local/bin/rmuser

    cat > /usr/local/bin/sharelink << 'EOF'
