#!/bin/bash
set -Eeuo pipefail

TRANSPORT="xhttp"
XRAY_DIR="/usr/local/etc/xray"
CONFIG_FILE="$XRAY_DIR/config.json"
KEYS_FILE="$XRAY_DIR/.keys"
INSTALLER_URL="https://github.com/XTLS/Xray-install/raw/main/install-release.sh"
BBR_CONF="/etc/sysctl.d/99-xray-bbr.conf"

log() {
    echo "[xhttp-xray-install] $*"
}

die() {
    echo "[xhttp-xray-install] Ошибка: $*" >&2
    exit 1
}

on_error() {
    local exit_code=$?
    echo "[xhttp-xray-install] Ошибка на строке ${BASH_LINENO[0]}: команда завершилась с кодом $exit_code" >&2
    exit "$exit_code"
}
trap on_error ERR

require_root() {
    [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "запустите скрипт от root"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "не найдена команда: $1"
}

check_os() {
    [[ -r /etc/os-release ]] || {
        log "Не удалось определить ОС, продолжаю best-effort"
        return
    }

    # shellcheck disable=SC1091
    . /etc/os-release
    if [[ "${ID:-}" != "ubuntu" || ! " 22.04 24.04 " =~ " ${VERSION_ID:-} " ]]; then
        log "Предупреждение: скрипт тестировался на Ubuntu 22.04/24.04, текущая ОС: ${PRETTY_NAME:-unknown}"
    fi
}

install_dependencies() {
    log "Устанавливаю зависимости"
    apt update
    apt install -y qrencode curl jq openssl
}

enable_bbr() {
    log "Настраиваю BBR"
    install -m 0644 /dev/null "$BBR_CONF"
    {
        echo "net.core.default_qdisc=fq"
        echo "net.ipv4.tcp_congestion_control=bbr"
    } > "$BBR_CONF"
    sysctl --system >/dev/null

    local current
    current="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || true)"
    if [[ "$current" == "bbr" ]]; then
        log "BBR включен"
    else
        log "Предупреждение: не удалось подтвердить BBR, текущее значение: ${current:-unknown}"
    fi
}

install_xray_core() {
    local tmp
    tmp="$(mktemp)"
    log "Скачиваю официальный установщик Xray"
    curl -4 -fsSL --retry 3 -o "$tmp" "$INSTALLER_URL"
    [[ -s "$tmp" ]] || die "установщик Xray пустой"
    bash -n "$tmp"
    bash "$tmp" install
    rm -f "$tmp"
}

key_value() {
    local name="$1"
    local value
    value="$(awk -F': *' -v name="$name" '
        BEGIN { IGNORECASE = 1 }
        $1 == name { print $2; exit }
    ' "$KEYS_FILE")"
    [[ -n "$value" ]] || return 1
    printf '%s\n' "$value"
}

keys_are_valid() {
    [[ -s "$KEYS_FILE" ]] || return 1
    [[ -n "$(key_value shortsid)" ]] || return 1
    [[ -n "$(key_value uuid)" ]] || return 1
    [[ -n "$(key_value PrivateKey)" || -n "$(key_value "Private key")" ]] || return 1
    [[ -n "$(key_value Password)" || -n "$(key_value PublicKey)" || -n "$(key_value "Public key")" ]] || return 1
}

ensure_keys() {
    mkdir -p "$XRAY_DIR"

    if keys_are_valid; then
        chmod 600 "$KEYS_FILE"
        log "Использую существующий файл ключей"
        return
    fi

    log "Создаю новый файл ключей"
    local uuid shortsid x25519_output private_key public_key tmp
    uuid="$(xray uuid)"
    shortsid="$(openssl rand -hex 8)"
    x25519_output="$(xray x25519)"
    private_key="$(awk -F': *' 'BEGIN { IGNORECASE = 1 } /PrivateKey|Private key/ { print $2; exit }' <<< "$x25519_output")"
    public_key="$(awk -F': *' 'BEGIN { IGNORECASE = 1 } /Password|PublicKey|Public key/ { print $2; exit }' <<< "$x25519_output")"

    [[ -n "$uuid" ]] || die "не удалось создать uuid"
    [[ -n "$shortsid" ]] || die "не удалось создать short id"
    [[ -n "$private_key" ]] || die "не удалось получить private key из xray x25519"
    [[ -n "$public_key" ]] || die "не удалось получить public key из xray x25519"

    tmp="$(mktemp "$XRAY_DIR/.keys.XXXXXX")"
    chmod 600 "$tmp"
    {
        echo "shortsid: $shortsid"
        echo "uuid: $uuid"
        echo "PrivateKey: $private_key"
        echo "Password: $public_key"
    } > "$tmp"
    mv "$tmp" "$KEYS_FILE"
    chmod 600 "$KEYS_FILE"
}

get_uuid() {
    key_value uuid
}

get_private_key() {
    key_value PrivateKey || key_value "Private key"
}

get_short_id() {
    key_value shortsid
}

config_transport() {
    jq -er '.inbounds[0].streamSettings.network' "$CONFIG_FILE" 2>/dev/null || true
}

existing_clients_json() {
    jq -cer '.inbounds[0].settings.clients' "$CONFIG_FILE" 2>/dev/null || return 1
}

default_clients_json() {
    jq -cn --arg uuid "$(get_uuid)" '[{"email":"main","id":$uuid,"flow":""}]'
}

backup_config() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local backup
    backup="$CONFIG_FILE.bak.$(date +%Y%m%d-%H%M%S)"
    cp -p "$CONFIG_FILE" "$backup"
    log "Создан бэкап конфига: $backup"
}

validate_json_file() {
    jq -e . "$1" >/dev/null
}

validate_xray_config() {
    local file="$1"
    validate_json_file "$file"
    if command -v xray >/dev/null 2>&1; then
        xray run -test -config "$file" >/dev/null
    fi
}

write_config() {
    local clients_json="$1"
    local tmp
    tmp="$(mktemp "$XRAY_DIR/config.json.XXXXXX")"
    chmod 644 "$tmp"

    cat > "$tmp" << EOF
{
    "log": {
        "loglevel": "warning"
    },
    "routing": {
        "domainStrategy": "IPIfNonMatch",
        "rules": [
            {
                "type": "field",
                "domain": [
                    "geosite:category-ads-all"
                ],
                "outboundTag": "block"
            },
            {
                "type": "field",
                "ip": [
                    "geoip:cn"
                ],
                "outboundTag": "block"
            }
        ]
    },
    "inbounds": [
        {
            "listen": "0.0.0.0",
            "port": 443,
            "protocol": "vless",
            "settings": {
                "clients": $clients_json,
                "decryption": "none"
            },
            "streamSettings": {
                "network": "xhttp",
                "xhttpSettings": {
                    "path": "/"
                },
                "security": "reality",
                "realitySettings": {
                    "show": false,
                    "target": "github.com:443",
                    "serverNames": [
                        "github.com",
                        "www.github.com"
                    ],
                    "privateKey": "$(get_private_key)",
                    "minClientVer": "",
                    "maxClientVer": "",
                    "maxTimeDiff": 0,
                    "shortIds": [
                        "$(get_short_id)"
                    ]
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ]
            }
        }
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ],
    "policy": {
        "levels": {
            "0": {
                "handshake": 3,
                "connIdle": 180
            }
        }
    }
}
EOF

    validate_xray_config "$tmp"
    backup_config
    mv "$tmp" "$CONFIG_FILE"
}

ensure_config() {
    mkdir -p "$XRAY_DIR"

    local clients_json
    if [[ -f "$CONFIG_FILE" && "$(config_transport)" == "$TRANSPORT" ]]; then
        log "Сохраняю существующих клиентов из текущего XHTTP-конфига"
        clients_json="$(existing_clients_json)" || clients_json="$(default_clients_json)"
    else
        if [[ -f "$CONFIG_FILE" ]]; then
            log "Существующий конфиг не XHTTP или невалиден, будет создан новый конфиг с main-клиентом"
        fi
        clients_json="$(default_clients_json)"
    fi

    write_config "$clients_json"
}

restart_xray() {
    systemctl restart xray || die "не удалось перезапустить xray"
}

install_management_commands() {
    log "Обновляю команды управления пользователями"

    cat > /usr/local/bin/userlist << 'EOF'
#!/bin/bash
set -Eeuo pipefail
CONFIG_FILE="/usr/local/etc/xray/config.json"

mapfile -t emails < <(jq -r '.inbounds[0].settings.clients[].email' "$CONFIG_FILE")

if [[ ${#emails[@]} -eq 0 ]]; then
    echo "Список клиентов пуст"
    exit 1
fi

echo "Список клиентов:"
for i in "${!emails[@]}"; do
    echo "$((i + 1)). ${emails[$i]}"
done
EOF
    chmod +x /usr/local/bin/userlist

    cat > /usr/local/bin/mainuser << 'EOF'
